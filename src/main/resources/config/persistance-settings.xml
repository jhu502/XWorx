			<field name="companyCode" column="company" />	//Mapping from POJO field to Cassandra table column
			<field name="departmentCode" column="department" />
		</partitionKey>
		<clusterKey> //Cluster key fields if POJO strategy used
			<field name="number" column="number" sort="desc" /> //Mapping from POJO field to Cassandra table column
		</clusterKey>
	</keyPersistence>
	-->
	<valuePersistence class="com.flame.test.CatalogCategory" strategy="POJO"> <!-- Persistent settings for Ignite cache values -->
		<field name="id" column="id" />	<!-- Mapping from POJO field to Cassandra table column -->
		<field name="parentId" column="parentId" />
		<field name="name" column="name" />
		<field name="description" column="description" />
	</valuePersistence>
</persistence>