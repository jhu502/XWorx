                <attr name="name">visibility</attr>
                <attr name="type">XPropertyDefinition</attr>
            </where>
        </link>
        <link type="xw.action.entity.XActionItemLink" refer="left">
            <attr name="sort">20</attr>
            <where type="xw.action.entity.XActionItem" refer="right">
                <attr name="name">constraints</attr>
                <attr name="type">XPropertyDefinition</attr>
            </where>
        </link>
    </LoadObject>
</FlameDataLoad>