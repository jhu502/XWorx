<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE FlameDataLoad SYSTEM "../../StandardX01.dtd">
<FlameDataLoad loader="xw.action.ActionDataLoader" description="XThingModel ActionMenu">
    <LoadObject type="xw.action.entity.XActionItem" where="type,name">
        <attr name="name">visibility</attr>
        <attr name="type">XPropertyDefinition</attr>
        <attr name="display">Visibility</attr>
        <attr name="style"></attr>
        <attr name="url">thymeleaf/thing/model/propertyVisibilityTab.html</attr>
        <attr name="winType">page</attr>
        <attr name="en_US">Visibility</attr>
        <attr name="zh_CN">可见性</attr>
